# Build output
bin/
obj/

# Database (runtime data, not source)
*.db
*.db-shm
*.db-wal

# Real church import data (confidential — keep out of source control)
# Place your actual CSV exports in SeedData/ and they will be ignored.
# Only the sample_*.csv templates are tracked.
SeedData/*.csv
!SeedData/sample_*.csv

# User-specific VS files
*.user
.vs/
*.suo

# Generated PDFs
*.pdf

# Claude Code local config
.claude/

# OS
Thumbs.db
desktop.ini
.DS_Store
